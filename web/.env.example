# =============================================================================
# AEO Platform — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# AI API Keys (users can provide their own)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
GOOGLE_GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...
GROK_API_KEY=xai-...

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Cloud / Self-hosted mode
# Set to "true" only for the official cloud deployment.
# Self-hosted instances should leave this unset or "false" — all features
# will be unlocked automatically.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_IS_CLOUD=false

# -----------------------------------------------------------------------------
# AEO Server (backend API)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:80

# -----------------------------------------------------------------------------
# Stripe (cloud only — not needed for self-hosted)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
# STRIPE_GROWTH_MONTHLY_PRICE_ID=price_...

# -----------------------------------------------------------------------------
# Supabase Service Role Key (cloud only — for Stripe webhooks)
# -----------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
